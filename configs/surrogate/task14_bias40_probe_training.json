{
  "config_role": "current_task14_bias40_probe_training_contract",
  "execution_mode": "local_preparation_bias40_probe_contract",
  "model_type": "neural_residual_mlp_spectrum_surrogate",
  "dataset_manifest": "outputs/datasets/task14_bias40_probe/dataset.json",
  "checkpoint_dir": "outputs/checkpoints/task14_bias40_probe",
  "run_metadata_path": "outputs/runs/task14_bias40_probe_training_run_metadata.json",
  "run_kind": "task14_bias40_probe_training",
  "model_card_title": "Task 14 Bias40 Probe Checkpoint",
  "model_card_purpose_lines": [
    "Bias40 probe residual surrogate for the first widened-bias inverse-ready contract preparation.",
    "This probe is intended to isolate the effect of widening the spectrum window to [-40, 40] meV while preserving the Task 14 gauge-fixed 7+1 pairing representation contract."
  ],
  "model_card_limitations_lines": [
    "This checkpoint must only be generated later on the server after the Task 14 bias40 probe run is explicitly promoted.",
    "The probe is designed to widen the bias window only; expanded nuisance-domain and TB-pilot variation are deferred to later tasks."
  ],
  "pairing_representation_contract": {
    "pairing_representation_version": "projected_7plus1_gauge_fixed_v1",
    "storage_block": "controls.pairing_representation",
    "global_phase_only": true,
    "further_compression": "forbidden"
  },
  "output_spectrum_contract": {
    "bias_min_mev": -40.0,
    "bias_max_mev": 40.0,
    "num_bias": 241
  },
  "residual_hidden_width": 384,
  "residual_num_blocks": 5,
  "normalization": "layernorm",
  "activation": "gelu",
  "optimizer": "adamw",
  "learning_rate": 0.0004,
  "weight_decay": 0.00005,
  "batch_size": 48,
  "max_epochs": 450,
  "early_stopping_patience": 40,
  "random_seed": 1103,
  "device": "auto",
  "held_out_splits": [
    "validation",
    "test"
  ],
  "loss": {
    "kind": "weighted_mse_plus_first_difference",
    "reconstruction_weight": 1.0,
    "shape_weight": 0.15,
    "bias_weighting": {
      "kind": "center_window",
      "central_weight": 2.5,
      "outer_weight": 1.0,
      "central_bias_half_width_mev": 4.0
    }
  },
  "ensemble": {
    "enabled": true,
    "seeds": [
      1103,
      2207,
      3301
    ],
    "aggregation": "mean",
    "disagreement_summary": "per_spectrum_mean_std_and_max_std"
  },
  "frozen_direction_contract": {
    "direction_schema_version": "ar_inverse_direction_v1",
    "supported_truth_grade_modes": [
      "inplane_100",
      "inplane_110"
    ],
    "unsupported_modes": [
      "c_axis"
    ],
    "diagnostic_raw_angles": "excluded from this Task 14C probe contract"
  }
}
